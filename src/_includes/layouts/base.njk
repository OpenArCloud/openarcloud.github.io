<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }} - Open AR Cloud</title>
    <meta name="description" content="Open Spatial Computing Platform - Connecting physical and digital worlds through open standards">
    <link rel="icon" type="image/x-icon" href="/img/favicon.ico">
    <link rel="stylesheet" href="/css/style.css">
    <style>
        .nav-dropdown { position: relative; }
        .nav-dropdown-menu {
            display: none;
            position: absolute;
            top: 100%;
            left: 0;
            background: #fff;
            border: 1px solid rgba(14, 124, 134, 0.20);
            border-radius: 8px;
            box-shadow: 0 4px 16px rgba(0,0,0,0.10);
            min-width: 130px;
            z-index: 200;
            padding: 8px 0;
        }
        .nav-dropdown:hover .nav-dropdown-menu,
        .nav-dropdown.is-open .nav-dropdown-menu { display: block; }
        .nav-dropdown-menu a {
            display: block;
            padding: 9px 16px;
            font-size: 0.88rem;
            white-space: nowrap;
            color: inherit;
        }
        .nav-dropdown-menu a:hover { background: rgba(14, 124, 134, 0.07); }
        @media (max-width: 768px) {
            .nav-dropdown-menu {
                position: static;
                box-shadow: none;
                border: none;
                border-left: 2px solid rgba(14, 124, 134, 0.25);
                border-radius: 0;
                padding: 0 0 0 12px;
                margin: 4px 0 4px 8px;
            }
        }
    </style>
</head>
<body>
    <header class="site-header">
        <div class="container">
            <div class="header-content">
                <a href="/" class="logo">
                    <img src="/img/oarc-cloud-icon.png" alt="Open AR Cloud" class="logo-icon">
                    <strong>OpenARCloud</strong>
                </a>
                <button class="nav-toggle" aria-label="Toggle navigation" aria-expanded="false">
                    <span class="hamburger"></span>
                </button>
                <nav class="main-nav">
                    <a href="/">Home</a>
                    <a href="/platform/">Platform</a>
                    <a href="/testbeds/">Testbeds</a>
                    <a href="/github/">GitHub</a>
                    <a href="/in-action/">In Action</a>
                    <a href="/initiatives/openvps/">OpenVPS</a>
                    <div class="nav-dropdown">
                        <a href="/about/">About</a>
                        <div class="nav-dropdown-menu">
                            <a href="/about/">Team</a>
                            <a href="https://medium.com/openarcloud" target="_blank" rel="noopener noreferrer">News</a>
                        </div>
                    </div>
                    <a href="https://ko-fi.com/openarcloud" target="_blank">Join</a>
                    <a href="https://ko-fi.com/openarcloud" target="_blank">Donate</a>
                </nav>
            </div>
        </div>
    </header>

    <main class="main-content">
        <div class="container">
            {{ content | safe }}
        </div>
    </main>

    <footer class="site-footer">
        <div class="container">
            <div class="footer-content">
                <div class="footer-section">
                    <h3>Open AR Cloud</h3>
                    <p>Driving the development of open and interoperable spatial computing technology.</p>
                </div>
                <div class="footer-section">
                    <h3>Quick Links</h3>
                    <ul>
                        <li><a href="/platform/">OSCP Platform</a></li>
                        <li><a href="https://github.com/OpenARCloud" target="_blank">GitHub Repos</a></li>
                        <li><a href="/partners/">Partners</a></li>
                        <li><a href="https://ko-fi.com/openarcloud" target="_blank">Membership</a></li>
                        <li><a href="/about/#contact">Contact</a></li>
                    </ul>
                </div>
                <div class="footer-section">
                    <h3>Connect</h3>
                    <ul>
                        <li><a href="https://github.com/OpenARCloud" target="_blank">GitHub</a></li>
                        <li><a href="https://x.com/openarcloud" target="_blank">Twitter</a></li>
                        <li><a href="https://www.linkedin.com/company/openarcloud" target="_blank">LinkedIn</a></li>
                        <li><a href="https://www.youtube.com/@openarcloud" target="_blank">YouTube</a></li>
                        <li><a href="mailto:info@openarcloud.org">Email</a></li>
                    </ul>
                </div>
            </div>
            <div class="footer-bottom">
                <p>&copy; 2026 Open AR Cloud Association. All rights reserved.</p>
            </div>
        </div>
    </footer>
    <script>
        const navToggle = document.querySelector('.nav-toggle');
        const mainNav = document.querySelector('.main-nav');

        navToggle.addEventListener('click', () => {
            const isOpen = mainNav.classList.toggle('is-open');
            navToggle.classList.toggle('is-open');
            navToggle.setAttribute('aria-expanded', isOpen);
        });

        // Dropdown toggle on mobile (click) — desktop uses CSS hover
        document.querySelectorAll('.nav-dropdown > a').forEach(trigger => {
            trigger.addEventListener('click', e => {
                if (window.innerWidth <= 768) {
                    e.preventDefault();
                    trigger.parentElement.classList.toggle('is-open');
                }
            });
        });
    </script>
</body>
</html>